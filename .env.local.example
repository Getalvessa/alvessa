# ============================================================
# Zenzo — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zenzo

# --- Supabase (Phase 2: Database & Auth) ---
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 5: Payments) ---
# Use test keys for development, live keys for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Google Maps (Phase 4: Booking Engine) ---
# Restrict this key to your domain in Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Email (Phase 4: Booking confirmations) ---
# Resend, Postmark, or SendGrid
EMAIL_FROM=noreply@zenzo.nl
EMAIL_API_KEY=

# --- Analytics (Phase 8: Optimization) ---
# Plausible (privacy-first, GDPR-compliant)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
