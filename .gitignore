# ============================================================
# Zenzo Marketplace — .gitignore
# ============================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js build artifacts ---
/.next/
/out/
/build

# --- Testing ---
/coverage

# --- Environment variables — NEVER commit secrets ---
.env
.env.local
.env.production
.env.development
.env.*.local
# .env.local.example is intentionally committed (no real values)

# --- Supabase local development ---
/supabase/.branches
/supabase/.temp
/supabase/config.toml.local

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
/logs

# --- OS files ---
.DS_Store
.DS_Store?
._*
Thumbs.db

# --- Editor files ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- TypeScript build cache ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- Certificates ---
*.pem

# --- Misc ---
.turbo
